function(dump_var name)
    message(STATUS "${name}=${${name}}")
endfunction()

set(DEBUG ON)
if(DEBUG)
    set(COMMAND_ECHO "STDOUT")
else()
    set(COMMAND_ECHO "NONE")
endif()

if(DEBUG)
    dump_var(HC)
    dump_var(ASCIIDOCTOR)
    dump_var(ADOC_FILE)
    dump_var(HTML_FILE)
    dump_var(CHECK_FILE)
    dump_var(PARAMETERS)
    message(STATUS "Parameters:")
    foreach(par ${PARAMETERS})
        message(STATUS "    ${par}")
    endforeach()
endif()

set(asciidoctor_cmd "${ASCIIDOCTOR}")
if(WIN32 AND EXISTS "${ASCIIDOCTOR}.bat")
    set(asciidoctor_cmd "${ASCIIDOCTOR}.bat")
endif()

execute_process(COMMAND "${HC}" ${PARAMETERS}
    COMMAND_ERROR_IS_FATAL ANY
    COMMAND_ECHO ${COMMAND_ECHO})

execute_process(COMMAND "${asciidoctor_cmd}" -o "${HTML_FILE}" "${ADOC_FILE}"
    COMMAND_ERROR_IS_FATAL ANY
    COMMAND_ECHO ${COMMAND_ECHO})

file(READ "${HTML_FILE}" html)
file(READ "${CHECK_FILE}" check_text)
string(REPLACE "\r\n" "\n" check_text "${check_text}")
string(REPLACE "\r" "\n" check_text "${check_text}")
while(NOT check_text STREQUAL "")
    string(FIND "${check_text}" "\n" newline)
    if(newline EQUAL -1)
        set(check "${check_text}")
        set(check_text "")
    else()
        string(SUBSTRING "${check_text}" 0 ${newline} check)
        math(EXPR next_line "${newline} + 1")
        string(SUBSTRING "${check_text}" ${next_line} -1 check_text)
    endif()
    if(check STREQUAL "" OR check MATCHES "^#")
        continue()
    endif()
    if(check MATCHES "^contains:(.*)$")
        string(FIND "${html}" "${CMAKE_MATCH_1}" found)
        if(found EQUAL -1)
            message(FATAL_ERROR "Rendered HTML does not contain: ${CMAKE_MATCH_1}")
        endif()
    elseif(check MATCHES "^not-contains:(.*)$")
        string(FIND "${html}" "${CMAKE_MATCH_1}" found)
        if(NOT found EQUAL -1)
            message(FATAL_ERROR "Rendered HTML contains: ${CMAKE_MATCH_1}")
        endif()
    else()
        message(FATAL_ERROR "Unknown render check: ${check}")
    endif()
endwhile()
